def jumlah_digit(n):
    if n == 0:
        return 0
    else:
        return (n % 10) + jumlah_digit(n // 10)
    
angka = 1234
hasil = jumlah_digit(angka)
print("Jumlah digit dari", angka, "adalah:", hasil)

total = int(input("Masukkan total belanja: "))

bayar = int(input("Uang dibayar: "))

while bayar < total:
    print("Uang kurang")
    bayar = int(input("Masukkan lagi: "))

kembalian = bayar - total

print("Total:",total)
print("Bayar:",bayar)

if kembalian == 0:
    print("Uang pas")
else:
    print("Kembalian:",kembalian)